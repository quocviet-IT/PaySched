# Supabase — project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.public-anon-key

# Server-only — never expose in browser bundle
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.service-role-key

# Postgres — Settings → Database → Connection string
# Use the "Transaction" pooler (port 6543) for app traffic
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# Use the "Session" pooler (port 5432) for migrations
DATABASE_URL_DIRECT=postgresql://postgres.YOUR-PROJECT-REF:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Vercel Cron — shared secret
CRON_SECRET=change-me-to-a-long-random-string

# Storage
SUPABASE_STORAGE_BUCKET=uploads
